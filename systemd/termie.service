[Unit]
Description=KARI Termie Fullscreen Log Viewer
After=multi-user.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory={{PROJECT_DIR}}
Environment=PYTHONUNBUFFERED=1
Environment=DHM_DASH_CONFIG={{DASH_CONFIG}}
Environment=TERMIE_LOG_PATH=/tmp/termie.log
Environment=TERMIE_EXIT_CMD={{PROJECT_DIR}}/stop_termie.sh
ExecStart={{PROJECT_DIR}}/bin/termie
Restart=on-failure
RestartSec=1
KillSignal=SIGINT
TimeoutStopSec=5

[Install]
WantedBy=multi-user.target
