# KARI watchdog configuration
# Restart/reboot threshold
KARI_WD_MAX_FAILURES=5
KARI_WD_RECHECK_DELAY=6
KARI_WD_REBOOT_ON_FAIL=true
KARI_WD_BOOT_GRACE_SECONDS=180

# Connectivity checks
KARI_WD_PING_TARGETS="1.1.1.1 8.8.8.8"
KARI_WD_LAUNCHER_URL="http://127.0.0.1:8787/"
KARI_WD_RASPYJACK_URL="http://127.0.0.1:8080"
KARI_WD_CHECK_INTERNET=true
KARI_WD_CHECK_TAILSCALE=true
KARI_WD_CHECK_LAUNCHER=true
KARI_WD_CHECK_RASPYJACK=false
# If false, internet-only ping failures are treated as degraded (no network restart/reboot).
KARI_WD_TREAT_INTERNET_ONLY_DOWN_AS_FAILURE=false

# Services to restart during self-heal
KARI_WD_NETWORK_SERVICES="NetworkManager.service"
KARI_WD_TAILSCALE_SERVICE="tailscaled.service"
KARI_WD_LAUNCHER_SERVICE="kari-dashboard.service"
KARI_WD_RASPYJACK_SERVICES="raspyjack-webui.service caddy.service raspyjack.service raspyjack-device.service"
