PING_RE = re.compile(r"time=([0-9.]+)\s*ms")
SMB_BLOCKS_RE = re.compile(r"(\d+)\s+blocks of size\s+(\d+)\.\s+(\d+)\s+blocks available", re.IGNORECASE)
SMB_ENTRY_RE = re.compile(r"^\s*(.+?)\s+([A-Z]+)\s+(\d+)\s+")
