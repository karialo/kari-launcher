          `uptime ${esc(ao.runtime_seconds ?? "n/a")}s | panics ${esc(ao.panic_count)} | sockets ${esc(sock)}<br>` +
          `caps hc/pcap ${esc(ao.hc22000_files)}/${esc(ao.pcap_files)} kis/tar ${esc(ao.kismet_files)}/${esc(ao.tar_files)}<br>` +
          `4wh/pmkid ${esc(ao.fourway_hashes)}/${esc(ao.pmkid_hashes)} | m1/rm2 ${esc(ao.m1_sent_events)}/${esc(ao.rogue_m2_events)}<br>` +
          `ssids/wl ${esc(ao.discovered_ssids)}/${esc(ao.whitelist_count)} | results ${esc(ao.result_files)}/${esc(fmtBytes(ao.result_size_bytes))} | log ${esc(fmtBytes(ao.log_size_bytes))}`;

        document.getElementById("aolog").textContent = (ao.log_lines && ao.log_lines.length) ? ao.log_lines.join("\\n") : "(no log lines)";
        requestAnimationFrame(syncWindowHeight);
      } catch (e) {
        document.getElementById("meta").textContent = `error: ${String(e)}`;
