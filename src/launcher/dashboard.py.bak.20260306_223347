    def _draw_angryoxide_page(self, theme: Theme, snap: Snapshot) -> None:
        ao = snap.angryoxide
        page_key = "angryoxide"

        card = pygame.Rect(10, 58, 300, 150)
        self._draw_card(card, theme, alt=True)

        run_state = "RUNNING" if ao.running else "STOPPED"
        run_color = theme.ok if ao.running else theme.warn

        self._draw_layered_heading(theme, label="ANGRYOXIDE", title="AngryOxide", pos=(20, 58))
        self._blit_text(run_state, 30, run_color, (20, 94))

        lines: list[str] = []
        if not self.angryoxide_log_view:
            sock_text = (
                f"{ao.sockets_rx}/{ao.sockets_tx}"
                if (ao.sockets_rx is not None and ao.sockets_tx is not None)
                else "n/a"
            )
            lines.extend(
                [
                    f"iface: {ao.iface} ({ao.iface_mode})",
                    f"pid: {ao.pid if ao.pid else 'n/a'}",
                    f"uptime: {ao.runtime_seconds if ao.runtime_seconds is not None else 'n/a'}s",
                    f"caps hc/pcap: {ao.hc22000_files}/{ao.pcap_files}",
                    f"caps kis/tar: {ao.kismet_files}/{ao.tar_files}",
                    f"4wh/pmkid: {ao.fourway_hashes}/{ao.pmkid_hashes}",
                    f"m1sent/rm2: {ao.m1_sent_events}/{ao.rogue_m2_events}",
                    f"ssids/wl: {ao.discovered_ssids}/{ao.whitelist_count}",
                    f"sockets rx/tx: {sock_text}",
                    f"oui: {ao.oui_records if ao.oui_records is not None else 'n/a'} panics: {ao.panic_count}",
                    f"results: {ao.result_files} / {format_bytes(ao.result_size_bytes)}",
                    f"log: {format_bytes(ao.log_size_bytes)} age {int(ao.log_age_seconds) if ao.log_age_seconds is not None else 'n/a'}s",
                ]
            )
        else:
            lines.append("live log tail:")
            if ao.log_lines:
                lines.extend(ao.log_lines[-5:])
            else:
                lines.append("(no log lines yet)")

        # Keep summary focused to fit without scrolling (X is run/stop on this page).
        if not self.angryoxide_log_view:
            lines = [
                lines[0],  # iface
                lines[2],  # uptime
                lines[3],  # caps hc/pcap
                lines[5],  # 4wh/pmkid
                lines[7],  # ssids/wl
                lines[11],  # log size/age
            ]
        else:
            lines = lines[:6]

        lines = [clean_text(x, 52) for x in lines]
