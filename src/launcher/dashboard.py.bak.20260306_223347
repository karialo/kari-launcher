  <script>
    const tokenEl = document.getElementById("token");
    const saved = localStorage.getItem("portable_ops_token");
    if (saved) tokenEl.value = saved;

    const views = Array.from(document.querySelectorAll(".window"));
    let lastView = "overview";

    function saveToken(){ localStorage.setItem("portable_ops_token", tokenEl.value.trim()); }
    function headers(){
      const t = tokenEl.value.trim();
      const h = {};
      if (t) h["X-Token"] = t;
      return h;
    }
    function esc(v){
      return String(v ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }
    function fmtBytes(v){
      if (v === null || v === undefined) return "n/a";
      let n = Number(v); const units = ["B","KB","MB","GB","TB"]; let i = 0;
      while (n >= 1024 && i < units.length - 1){ n /= 1024; i += 1; }
      return (i === 0 ? Math.round(n) : n.toFixed(1)) + units[i];
    }
    function yn(v){ return v ? "yes" : "no"; }
    function toNum(v){
      const n = Number(v);
      return Number.isFinite(n) ? n : null;
    }
    function latencyFill(lat){
      const n = toNum(lat);
      if (n === null) return 18;
      return Math.max(8, Math.min(100, 100 - (n * 1.4)));
    }
    function viewKey(page){
      const p = String(page || "");
      if (p.startsWith("node:")) return "node";
      if (p === "raspyjack" || p === "angryoxide" || p === "overview") return p;
      return "overview";
    }
    function setView(page){
      const key = viewKey(page);
      for (const el of views){
        const on = el.dataset.view === key;
        el.classList.toggle("active", on);
        el.classList.toggle("hidden", !on);
      }
      requestAnimationFrame(syncWindowHeight);
      if (key !== lastView){
        const active = document.querySelector(".window.active");
        if (active){
          active.classList.remove("pop");
          void active.offsetWidth;
          active.classList.add("pop");
        }
        lastView = key;
      }
    }
    function syncWindowHeight(){
      const stack = document.querySelector(".window-stack");
      const active = document.querySelector(".window.active");
      if (!stack || !active) return;
      const h = Math.max(242, active.scrollHeight + 6);
      stack.style.height = `${h}px`;
    }
    async function act(action){
      try {
        const res = await fetch("/api/action", {
          method: "POST",
          headers: { "Content-Type": "application/json", ...headers() },
          body: JSON.stringify({ action })
        });
        const data = await res.json();
        if (!data.ok) alert(data.message || "action failed");
      } catch (e) {
        alert(String(e));
      }
      setTimeout(load, 210);
    }
    async function load(){
      document.getElementById("clock").textContent = new Date().toLocaleTimeString();
      try {
        const res = await fetch("/api/status", { headers: headers() });
        const d = await res.json();
        if (!d.ok) throw new Error(d.message || "status error");

        document.getElementById("meta").textContent = `${d.hostname} | tailscale ${d.local.tailscale_ip}`;
        document.getElementById("theme").textContent = d.theme;
        document.getElementById("page").textContent = `page ${d.page}`;
        document.getElementById("note").textContent = d.status_note || "ready";

        document.getElementById("kpiCpu").textContent = `${d.local.cpu_temp_c ?? "n/a"} C`;
        document.getElementById("kpiLoad").textContent = String(d.local.load1 ?? "n/a");
        document.getElementById("kpiRam").textContent = `${d.local.mem_used_pct ?? "n/a"} %`;
        document.getElementById("kpiBattery").textContent =
          (d.local.battery_pct === null || d.local.battery_pct === undefined)
            ? "n/a"
            : `${Math.round(Number(d.local.battery_pct))} %`;
        if (d.local.wlan0_signal_pct !== null && d.local.wlan0_signal_pct !== undefined){
          document.getElementById("kpiWifi").textContent =
            `${d.local.wlan0_signal_pct}% (${d.local.wlan0_signal_dbm ?? "n/a"} dBm)`;
        } else if (d.local.wlan0_signal_dbm !== null && d.local.wlan0_signal_dbm !== undefined){
          document.getElementById("kpiWifi").textContent = `${d.local.wlan0_signal_dbm} dBm`;
        } else {
          document.getElementById("kpiWifi").textContent = "n/a";
        }

        document.getElementById("local").innerHTML =
          `host ${esc(d.hostname)} | tailscale ${esc(d.local.tailscale_ip)}<br>` +
          `battery ${esc(d.local.battery_pct ?? "n/a")}${d.local.battery_pct === null || d.local.battery_pct === undefined ? "" : "%"} | wlan0 ${esc(d.local.wlan0_signal_dbm ?? "n/a")} dBm<br>` +
          `active page ${esc(d.page)} | status ${esc(d.status_note || "ready")}`;
        document.getElementById("ovHost").textContent = String(d.hostname || "n/a");
        document.getElementById("ovTs").textContent = String(d.local.tailscale_ip || "n/a");
        document.getElementById("ovPage").textContent = String(d.page || "n/a");
        document.getElementById("ovStatus").textContent = String(d.status_note || "ready");

        setView(d.page);

        const nodes = document.getElementById("nodes");
        nodes.innerHTML = "";
        for (const n of d.nodes){
          const cls = n.status === "online" ? "online" : (n.status === "degraded" ? "degraded" : "offline");
          const fill = latencyFill(n.latency_ms);
          const div = document.createElement("div");
          div.className = "node";
          div.innerHTML =
            `<div class="node-top"><b>${esc(n.name)}</b><span class="${cls}">${esc(n.status)}</span></div>` +
            `<div class="node-host">${esc(n.host)}</div>` +
            `<div class="node-host">lat ${esc(n.latency_ms ?? "n/a")}ms | smb ${esc(n.smb_text || "n/a")}</div>` +
            `<div class="signal"><span style="width:${fill}%;"></span></div>`;
          nodes.appendChild(div);
        }

        let nodeText = "switch to a node page with A/B";
        if (String(d.page).startsWith("node:")){
          const name = String(d.page).slice(5);
          const node = (d.nodes || []).find((n) => String(n.name) === name);
          if (node){
            nodeText =
              `name ${esc(node.name)} | status ${esc(node.status)}<br>` +
