AO_OUI_RE = re.compile(r"OUI Records Imported:\s*(\d+)")
AO_SSID_RE = re.compile(r"SSID:\s*([^\r\n]+)")
AO_WL_ARG_RE = re.compile(r"--whitelist-entry\s+([^\s]+)")
