IW_SIGNAL_RE = re.compile(r"signal:\s*(-?\d+(?:\.\d+)?)\s*dBm", re.IGNORECASE)
PISUGAR_BATTERY_RE = re.compile(r"battery[^0-9-]*([0-9]{1,3}(?:\.[0-9]+)?)", re.IGNORECASE)
